# Maintainer: Publisher Contributors <contact@publisher.app>
pkgname=publisher-desktop
pkgver=0.1.0
pkgrel=1
pkgdesc="Professional print-first desktop publishing application"
arch=('aarch64' 'x86_64')
url="https://github.com/atcen/publisher"
license=('AGPL3')
depends=('webkit2gtk-4.1' 'openssl' 'libnm' 'vulkan-driver')
makedepends=('cargo' 'node-lts-iron' 'npm')
source=("publisher-$pkgver.tar.gz::https://github.com/atcen/publisher/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "publisher-$pkgver"
  npm install --prefix apps/web
  cargo build --release -p publisher-desktop
}

package() {
  cd "publisher-$pkgver"
  install -Dm755 "target/release/publisher-desktop" "$pkgdir/usr/bin/publisher"
  install -Dm644 "apps/desktop/src-tauri/icons/32x32.png" "$pkgdir/usr/share/icons/hicolor/32x32/apps/publisher.png"
}
