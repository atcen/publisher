#!/bin/sh

echo "🔍 Running local tests before commit..."

# Run Rust tests
echo "📝 Running cargo test..."
cargo test --workspace || exit 1

# Run clippy
echo "🔍 Running clippy..."
cargo clippy --workspace --all-targets -- -D warnings || exit 1

# Run cargo fmt check
echo "📐 Checking formatting..."
cargo fmt --check || exit 1

# Check coverage (non-blocking, just informational)
echo ""
echo "📊 Checking test coverage..."
if command -v cargo-tarpaulin &> /dev/null; then
  cargo tarpaulin --workspace --skip-clean --timeout 300 --out Stdout 2>/dev/null | grep "Coverage:" || true
else
  echo "⚠️  cargo-tarpaulin not installed, skipping coverage check"
fi

echo "✅ All checks passed!"
